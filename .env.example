# ============================
# Fiyatcim.com Environment Variables
# ============================

# Demo Mode (zorunlu)
# true: seed data + localStorage auth — geliştirme/demo ortamı
# false: Supabase DB + Supabase Auth — üretim ortamı
NEXT_PUBLIC_DEMO_MODE=true

# Supabase (zorunlu — demo mode'da bile Supabase client oluşturulur)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Demo Admin Secret (ZORUNLU — demo mode admin auth için)
# 32+ karakter rastgele string kullanın: openssl rand -hex 32
DEMO_ADMIN_SECRET=change-me-to-a-random-secret-string

# E-posta — Resend (opsiyonel)
# Eksikse sipariş/bildirim e-postaları gönderilmez, console'da uyarı loglanır
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=Fiyatcim <noreply@fiyatcim.com>

# Google Analytics (opsiyonel)
# Eksikse analytics devre dışı kalır
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Payment — iyzico (opsiyonel, Sprint 4)
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Deploy Safety Gate (opsiyonel)
# production olarak ayarlanırsa ve DEMO_MODE=true ise build başarısız olur
# DEPLOY_TARGET=production
